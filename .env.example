# =============================================================================
# Environment Variables - Template
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control!
# =============================================================================

# --- Next.js -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=AgroPark Nekrasovo

# --- AI API (OpenAI-compatible endpoint) -------------------------------------
# Optional. If omitted, the chatbot falls back to rule-based responses.
AI_API_URL=https://your-ai-endpoint.com/api
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o-mini

# --- Optional: Future backend integrations -----------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# SUPABASE_DB_SCHEMA=public
# NEXT_PUBLIC_GA_TRACKING_ID=
# RESEND_API_KEY=
